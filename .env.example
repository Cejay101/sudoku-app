# ─── Server ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local dev:  postgresql://user:password@localhost:5432/sudoku
# Railway:    provided automatically as DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/sudoku"

# Allowed client origin (Next.js URL)
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_ORIGIN="http://localhost:3000"

# Server port (Railway sets this automatically)
PORT=3001

# ─── Client (Next.js) ────────────────────────────────────────────────────────
# Prefix with NEXT_PUBLIC_ to expose to the browser

# Backend server URL for socket.io
# Local dev:  http://localhost:3001
# Production: https://your-server.railway.app
NEXT_PUBLIC_SERVER_URL="http://localhost:3001"
